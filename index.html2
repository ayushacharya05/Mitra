<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MITRA AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;550&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body {
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            background: #f1f3f5;
            overflow: hidden;
        }

        /* Desktop Container */
        .app {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            max-width: 900px; /* Wider for Desktop */
            margin: 0 auto;
            background: white;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        .header {
            height: 70px;
            padding: 1rem;
            text-align: center;
            background: #fff;
            border-bottom: 1px solid #eee;
            flex-shrink: 0;
        }
        .header h1 {
            font-weight: 550;
            font-size: 28px;
            margin: 0;
            background: linear-gradient(90deg, #111, #555);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .chat-area {
            position: absolute;
            top: 70px;
            left: 0;
            right: 0;
            bottom: 80px;
            overflow-y: auto;
            padding: 1.5rem;
            background: #f9f9fb;
            scroll-behavior: smooth;
        }
        .chat-box {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .input-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 1rem;
            background: white;
            border-top: 1px solid #eee;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        /* Buttons */
        .btn-circle {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            transition: 0.3s;
        }
        .btn-speaker { background: #e0e0e0; color: #666; }
        .btn-speaker.on { background: #28a745; color: white; }
        .btn-send { background: #1976d2; color: white; }
        
        .form-control {
            border-radius: 24px;
            padding: 0.7rem 1.2rem;
            border: 1px solid #ddd;
        }

        /* Message Bubbles */
        .user-msg, .ai-msg {
            padding: 0.8rem 1.2rem;
            border-radius: 18px;
            font-size: 1rem;
            max-width: 80%;
            line-height: 1.5;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .user-msg {
            background: #1976d2;
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 2px;
        }
        .ai-msg {
            background: white;
            color: #333;
            align-self: flex-start;
            border: 1px solid #eee;
            border-bottom-left-radius: 2px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }
        .ai-icon {
            width: 24px;
            height: 24px;
            border-radius: 4px;
            flex-shrink: 0;
            margin-top: 3px;
        }

        /* Kebab & About */
        #kebab-menu {
            position: fixed;
            top: 60px; right: 20px;
            width: 150px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            display: none;
            z-index: 2000;
        }
        #kebab-menu.show { display: block; }
        .kebab-item {
            padding: 10px 15px;
            display: block;
            text-decoration: none;
            color: #333;
            font-size: 14px;
        }
        .kebab-item:hover { background: #f5f5f5; }

        #aboutOverlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 3000;
        }
        .about-card {
            background: white;
            width: 400px;
            padding: 2rem;
            border-radius: 20px;
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
        }
    </style>
</head>
<body>

<div class="app">
    <div class="header">
        <a href="#" style="text-decoration:none;"><h1>MITRA</h1></a>
    </div>

    <div class="chat-area" id="chatArea">
        <div class="chat-box" id="chatBox"></div>
    </div>

    <div class="input-bar">
        <button class="btn-circle btn-speaker" id="speechToggleBtn" onclick="toggleSpeech()">
            <i class="fas fa-volume-up"></i>
        </button>
        <input type="text" id="question" class="form-control" placeholder="Ask me anything..." onkeypress="if(event.key==='Enter') askAI()">
        <button class="btn-circle btn-send" onclick="askAI()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<div class="position-fixed top-0 end-0 p-3" style="z-index:2050;">
    <button id="kebab-btn" class="btn btn-light shadow-sm rounded-circle" style="width:40px; height:40px;">
        <i class="fas fa-ellipsis-v"></i>
    </button>
    <div id="kebab-menu">
        <a href="javascript:void(0)" class="kebab-item" onclick="showAbout()">About</a>
        <a href="mailto:support@example.com" class="kebab-item">Support</a>
    </div>
</div>

<div id="aboutOverlay">
    <div class="about-card text-center">
        <img src="https://raw.githubusercontent.com/ayushacharya05/Mitra/refs/heads/main/images/icon.png" width="60" class="mb-3">
        <h5>Mitra AI v1.0.3</h5>
        <p class="small text-muted">Created by Ayush Acharya</p>
        <hr>
        <p class="small">The first intelligent AI from Nepal with full local language support.</p>
        <button class="btn btn-dark btn-sm w-100 mt-3" onclick="hideAbout()">Close</button>
    </div>
</div>

<script>
    const chatBox = document.getElementById('chatBox');
    const chatArea = document.getElementById('chatArea');
    const questionInput = document.getElementById('question');
    const AI_ICON = "https://raw.githubusercontent.com/ayushacharya05/Mitra/refs/heads/main/images/icon.png";
    
    let isSpeechEnabled = false;

    // --- Core Logic ---
    function toggleSpeech() {
        isSpeechEnabled = !isSpeechEnabled;
        const btn = document.getElementById('speechToggleBtn');
        btn.classList.toggle('on', isSpeechEnabled);
    }

    function addMessage(sender, text) {
        const msgDiv = document.createElement('div');
        msgDiv.className = sender === 'user' ? 'user-msg' : 'ai-msg';
        
        if (sender === 'ai') {
            msgDiv.innerHTML = `<img src="${AI_ICON}" class="ai-icon"><span>${text}</span>`;
        } else {
            msgDiv.textContent = text;
        }

        chatBox.appendChild(msgDiv);
        chatArea.scrollTop = chatArea.scrollHeight;
    }

    async function fetchWebResult(query) {
        try {
            const res = await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json`);
            const data = await res.json();
            return data.AbstractText || "I couldn't find a direct answer. Try asking differently!";
        } catch (e) { return "Search failed. Check your connection."; }
    }

    function getPredefined(query) {
        const pairs = [
            { k: ["hi", "hello", "नमस्ते"], a: "Namaste! I am Mitra. How can I help you?" },
            { k: ["who made you", "creator"], a: "I was created by Ayush Acharya." },
            { k: ["joke"], a: "Why did the computer go to the doctor? It had a virus!" }
        ];
        const match = pairs.find(p => p.k.some(key => query.toLowerCase().includes(key)));
        return match ? match.a : null;
    }

    async function askAI() {
        const query = questionInput.value.trim();
        if (!query) return;

        addMessage('user', query);
        questionInput.value = '';

        let response = getPredefined(query) || await fetchWebResult(query);
        
        setTimeout(() => {
            addMessage('ai', response);
            if (isSpeechEnabled) {
                window.speechSynthesis.cancel();
                const u = new SpeechSynthesisUtterance(response);
                u.lang = /[\u0900-\u097F]/.test(response) ? 'hi-IN' : 'en-US';
                window.speechSynthesis.speak(u);
            }
        }, 500);
    }

    // --- UI Logic ---
    function showAbout() { document.getElementById('aboutOverlay').style.display = 'block'; }
    function hideAbout() { document.getElementById('aboutOverlay').style.display = 'none'; }
    
    document.getElementById('kebab-btn').onclick = (e) => {
        e.stopPropagation();
        document.getElementById('kebab-menu').classList.toggle('show');
    };
    document.onclick = () => document.getElementById('kebab-menu').classList.remove('show');

    // Welcome
    window.onload = () => addMessage('ai', 'Namaste! I am your AI companion Mitra. Ask me anything in English or Nepali.');
</script>
</body>
</html>
